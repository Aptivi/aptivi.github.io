@page "/newsroom"
@inject IJSRuntime JSRuntime;

<PageTitle>Newsroom - Aptivi</PageTitle>

@using System.Threading;
@using System.Net;
@using System.Text;
@using aptivi.github.io.Data
@using System.IO
@using System.Text.Json
@inject NavigationManager NavManager

<Hero Title="Newsroom" Buttons="Callbacks">
	Aptivi Newsroom is coming soon! See this article for more info.
</Hero>

@code
{
	(EventCallback, string, bool)[] Callbacks =>
	[
		(EventCallback.Factory.Create(this, new Action(async () => await JSRuntime.InvokeVoidAsync("open", "https://officialaptivi.wordpress.com/2026/03/28/embracing-stability-and-security-of-our-projects/", "_blank"))), "Learn more", false)
	];
}
